{
  "repoPath": "/path/to/your/git/repo",
  "reportsPath": "tmp_docs/reviews",
  "maxParallelReviews": 1,
  "maxParallelCommitReviews": 1,
  "pollIntervalSeconds": 10,
  "codexHome": "~/.codex",
  "codexModel": null,
  "aiProvider": "codex",
  "cursorHome": "~/.cursor",
  "cursorModel": "composer-2.5",
  "reviewProfilePath": null,
  "reviewCachePath": "~/Library/Caches/com.ai-reviewer",
  "statePath": null,
  "reviewCurrentHeadOnStartup": false,
  "startWatcherOnLaunch": true,
  "hideDockIcon": true,
  "sweepDepth": 50,
  "retryFailedAfterSeconds": 3600,
  "codexTimeoutSeconds": 1800,
  "maxSnapshotBytes": 200000,
  "maxPromptSnapshotBytes": 500000,
  "maxCodexRunCacheEntries": 0,
  "maxBundleCacheEntries": 200
}
